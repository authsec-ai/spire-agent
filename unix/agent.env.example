# SPIRE Agent - Environment Variables
# Copy to /etc/spire-agent/agent.env and update values.
# This file is loaded by the systemd service.

# Required: Your tenant UUID from AuthSec
TENANT_ID=YOUR-TENANT-UUID

# Node identity — auto-set to hostname by install.sh
NODE_ID=unix-node-1

# ICP Service address (default is usually fine)
ICP_SERVICE_ADDRESS=https://prod.api.authsec.ai/spiresvc

# Logging (debug, info, warning, error)
LOG_LEVEL=info
