# ICP Agent Docker Deployment - Environment Variables
# Copy this file to .env and update values as needed.

# Tenant 1
TENANT_ID_1=477e9f97-d8a9-442a-8d92-f771393fab66
NODE_ID_1=docker-node-1
HEALTH_PORT_1=8080

# Tenant 2 (uncomment when enabling second tenant)
# TENANT_ID_2=your-second-tenant-id
# NODE_ID_2=docker-node-2
# HEALTH_PORT_2=8081

# ICP Service
ICP_SERVICE_ADDRESS=https://prod.api.authsec.ai/spiresvc

# Logging
LOG_LEVEL=info
